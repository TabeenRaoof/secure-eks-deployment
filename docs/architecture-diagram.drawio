        <mxCell id="sm" value="&lt;b&gt;Secrets Manager&lt;/b&gt;&#xa;App secrets bundle&#xa;Read via IRSA (backend only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="secLane">
          <mxGeometry x="15" y="125" width="250" height="65" as="geometry" />
        </mxCell>

        <mxCell id="iamBox" value="&lt;b&gt;IAM + IRSA + RBAC&lt;/b&gt;&#xa;Persona roles (admin/dev/viewer)&#xa;aws-auth → K8s groups&#xa;ClusterRoles / Roles / PSS namespace labels" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="secLane">
          <mxGeometry x="15" y="198" width="250" height="90" as="geometry" />
        </mxCell>

        <mxCell id="obsLane" value="&lt;b&gt;Monitoring &amp; response&lt;/b&gt;" style="swimlane;horizontal=0;startSize=36;fillColor=#d4e1f5;strokeColor=#6c8ebf;align=center;" vertex="1" parent="1">
          <mxGeometry x="1260" y="360" width="280" height="250" as="geometry" />
        </mxCell>

