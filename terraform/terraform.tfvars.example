# Copy this file to terraform.tfvars and update the values.
# WARNING: terraform.tfvars is in .gitignore — never commit secrets.

aws_region     = "us-west-2"
project_name   = "fintech-secure"
environment    = "dev"

vpc_cidr        = "10.0.0.0/16"
cluster_version = "1.29"

node_instance_types = ["t3.medium"]
node_desired_size   = 2
node_min_size       = 1
node_max_size       = 4

# Restrict API access to your team's IP addresses for security.
# Replace with actual CIDRs before deploying.
endpoint_public_access = true
public_access_cidrs    = ["0.0.0.0/0"]

enable_flow_logs = true

# Optional override (leave empty to use default: <project>-<env>-backend)
app_secrets_name = ""

# Phase 7: Container Security
# Set to false in production so ECR refuses to delete repos with images.
ecr_force_delete = true

# Phase 8: Monitoring & Logging
# Provide an email to receive CloudWatch alarm notifications (leave empty to skip).
# You must click the confirmation email sent by AWS SNS after apply.
alarm_email               = ""
enable_container_insights = true
