  <diagram id="secure-eks-arch" name="4 - Secure EKS Architecture">
    <mxGraphModel dx="1400" dy="850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Figure 4 — Secure Cloud-Native Fintech on AWS EKS&lt;/b&gt;&lt;br&gt;Defense in depth: network, identity, data, runtime, monitoring" style="text;html=1;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="800" height="40" as="geometry" />
        </mxCell>

        <!-- Internet -->
        <mxCell id="internet" value="Users / Internet&#xa;HTTPS (TLS 1.3 at ALB)&#xa;HTTP demo: port 80" style="shape=ellipse;perimeter=ellipsePerimeter;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="160" height="90" as="geometry" />
        </mxCell>

        <!-- VPC container -->
        <mxCell id="vpc" value="&lt;b&gt;Amazon VPC&lt;/b&gt; — 10.0.0.0/16 • Multi-AZ (3)&#xa;VPC Flow Logs → CloudWatch • NACLs (subnet boundary)" style="swimlane;horizontal=1;startSize=55;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="90" width="920" height="520" as="geometry" />
        </mxCell>

        <!-- Public subnets lane -->
        <mxCell id="publicLane" value="&lt;b&gt;Public subnets&lt;/b&gt; (per AZ)&#xa;ALB + NAT Gateway" style="swimlane;horizontal=0;startSize=120;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;fontStyle=0;" vertex="1" parent="vpc">
          <mxGeometry x="30" y="70" width="240" height="420" as="geometry" />
        </mxCell>

        <mxCell id="igw" value="Internet&#xa;Gateway&#xa;(IGW)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1" vertex="1" parent="publicLane">
          <mxGeometry x="50" y="50" width="120" height="70" as="geometry" />
        </mxCell>

        <mxCell id="alb" value="&lt;b&gt;Application Load Balancer&lt;/b&gt;&#xa;Internet-facing&#xa;ACM cert (TLS 1.3)&#xa;Security Group: 443/80 → nodes&#xa;Routes: / → frontend, /api → backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=0;align=center;" vertex="1" parent="publicLane">
          <mxGeometry x="25" y="160" width="170" height="130" as="geometry" />
        </mxCell>

        <mxCell id="nat" value="&lt;b&gt;NAT Gateway(s)&lt;/b&gt;&#xa;Outbound-only egress&#xa;for private subnets&#xa;(ECR, STS, Secrets Mgr)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="publicLane">
          <mxGeometry x="35" y="320" width="150" height="90" as="geometry" />
        </mxCell>

        <!-- Private / EKS lane -->
        <mxCell id="privateLane" value="&lt;b&gt;Private subnets&lt;/b> (per AZ)&#xa;Worker nodes: &lt;b&gt;no public IPs&lt;/b&gt;" style="swimlane;horizontal=0;startSize=120;fillColor=#d5e8d4;strokeColor=#82b366;align=center;" vertex="1" parent="vpc">
          <mxGeometry x="300" y="70" width="590" height="420" as="geometry" />
        </mxCell>

        <mxCell id="cp" value="&lt;b&gt;Amazon EKS control plane&lt;/b&gt; (managed)&#xa;API server • Audit logs → CloudWatch&#xa;Secrets encryption (KMS)&#xa;OIDC provider → IRSA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontStyle=0;align=left;spacingLeft=6;" vertex="1" parent="privateLane">
          <mxGeometry x="30" y="40" width="530" height="90" as="geometry" />
        </mxCell>

        <mxCell id="nodes" value="&lt;b&gt;Managed node group&lt;/b&gt; (e.g. t3.medium)&#xa;Launch Template: encrypted gp3 EBS&#xa;Node IAM role (least privilege)&#xa;Cluster + Node Security Groups" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;align=left;spacingLeft=6;" vertex="1" parent="privateLane">
          <mxGeometry x="30" y="150" width="250" height="110" as="geometry" />
        </mxCell>

        <mxCell id="fe" value="&lt;b&gt;Pods: Frontend&lt;/b&gt;&#xa;nginx (non-root)&#xa;Service :80 → :8080" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;" vertex="1" parent="privateLane">
          <mxGeometry x="320" y="150" width="110" height="95" as="geometry" />
        </mxCell>

        <mxCell id="be" value="&lt;b&gt;Pods: Backend&lt;/b&gt;&#xa;Flask / gunicorn&#xa;IRSA ServiceAccount&#xa;PSS &lt;i&gt;restricted&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;" vertex="1" parent="privateLane">
          <mxGeometry x="440" y="150" width="120" height="110" as="geometry" />
        </mxCell>

        <mxCell id="db" value="&lt;b&gt;Pods: PostgreSQL&lt;/b&gt;&#xa;StatefulSet&#xa;PVC: encrypted volume" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;" vertex="1" parent="privateLane">
          <mxGeometry x="320" y="280" width="240" height="75" as="geometry" />
        </mxCell>

        <mxCell id="np" value="&lt;b&gt;NetworkPolicies&lt;/b&gt;&#xa;Default deny ingress/egress&#xa;Allow: ALB→FE→BE→DB; BE→443 (AWS APIs); DNS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#ad1457;align=left;spacingLeft=4;fontSize=11;" vertex="1" parent="privateLane">
          <mxGeometry x="30" y="280" width="260" height="85" as="geometry" />
        </mxCell>

        <!-- Security & observability column -->
