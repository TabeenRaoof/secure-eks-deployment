        </mxCell>

        <mxCell id="kms" value="&lt;b&gt;KMS (CMK)&lt;/b&gt;&#xa;EBS, EKS secrets, Secrets Mgr,&#xa;ECR, SNS topic encryption" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="secLane">
