        </mxCell>

        <mxCell id="gd" value="&lt;b&gt;GuardDuty&lt;/b&gt;&#xa;EKS audit findings • VPC/DNS/Trail&#xa;EBS malware protection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="obsLane">
          <mxGeometry x="15" y="125" width="250" height="60" as="geometry" />
        </mxCell>

        <mxCell id="sns" value="&lt;b&gt;SNS&lt;/b&gt; (KMS-encrypted)&#xa;Alarm notifications → email / ops" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="obsLane">
          <mxGeometry x="15" y="195" width="250" height="50" as="geometry" />
        </mxCell>

        <!-- ECR / CI -->
        <mxCell id="ecr" value="&lt;b&gt;Amazon ECR&lt;/b&gt;&#xa;Immutable tags • scan-on-push&#xa;Inspector enhanced scanning • KMS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#cc6c00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="660" width="200" height="85" as="geometry" />
